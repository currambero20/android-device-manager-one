{
  "name": "repo_deploy",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "npm run dev --prefix client",
    "build": "npm install --prefix client --legacy-peer-deps && npm run build --prefix client && mkdir -p public && cp -r client/dist/* public/",
    "start": "npx tsx server/_core/index.ts",
    "postinstall": "npm install --prefix client --legacy-peer-deps"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/lib-storage": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@trpc/server": "^11.6.0",
    "axios": "^1.12.0",
    "bcrypt": "^6.0.0",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.44.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "jose": "^6.1.0",
    "mysql2": "^3.15.0",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.3",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "speakeasy": "^2.0.0",
    "superjson": "^1.13.3",
    "tsx": "^4.19.1",
    "typescript": "^5.7.2",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^24.7.0",
    "@types/nodemailer": "^7.0.11",
    "@vercel/node": "^5.7.10",
    "javascript-obfuscator": "^5.4.1",
    "vite-plugin-javascript-obfuscator": "^3.1.0"
  }
}