{
  "version": 2,
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/trpc/(.*)", "destination": "https://android-device-manager-one.onrender.com/api/trpc/$1" },
    { "source": "/api/(.*)", "destination": "https://android-device-manager-one.onrender.com/api/$1" },
    { "source": "/adm-ws(.*)", "destination": "https://android-device-manager-one.onrender.com/adm-ws$1" },
    { "source": "/socket.io/(.*)", "destination": "https://android-device-manager-one.onrender.com/socket.io/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}