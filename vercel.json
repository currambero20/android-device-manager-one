{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "installCommand": "npm install",
  "build": {
    "env": {
      "NODE_OPTIONS": "--require tsx"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/vercel.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}